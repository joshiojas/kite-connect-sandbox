# Kite Connect Sandbox — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env with real keys.

# Mode: "sandbox" (default) simulates orders locally; "proxy" forwards all requests to upstream Kite API
SANDBOX_MODE=sandbox

SANDBOX_PORT=8000
SANDBOX_LOG_LEVEL=info
SANDBOX_INITIAL_CAPITAL=1000000
SANDBOX_PERSISTENCE=sqlite          # "sqlite" or "memory"
SANDBOX_DB_PATH=/data/sandbox.db
SANDBOX_RESET_ON_RESTART=false

# Upstream Kite API (user provides their own credentials)
KITE_BASE_URL=https://api.kite.trade
KITE_WS_URL=wss://ws.kite.trade
KITE_UPSTREAM_TIMEOUT=10000

# Optional: Webhook URL for order fill notifications
# SANDBOX_WEBHOOK_URL=http://localhost:9000/webhook

# Proxy mode: structured JSONL log file path (only used when SANDBOX_MODE=proxy)
# LOG_FILE_PATH=/data/logs/kite-proxy.log
